// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum IncidentType {
  drain
  citizen
}

enum Audience {
  ops
  public
}

enum RiskTier {
  SAFE
  MEDIUM
  HIGH
}

model Forecast {
  id         String   @id @default(uuid())
  zone       String
  rainProb   Float
  rainAmount Float?
  riskScore  Float    @default(0)
  timestamp  DateTime @default(now())

  @@map("fg_forecasts")
  @@index([zone, timestamp])
}

model Incident {
  id           String       @id @default(uuid())
  type         IncidentType
  description  String
  zone         String
  photoUrl     String?
  locationName String?
  latitude     Float?
  longitude    Float?
  timestamp    DateTime     @default(now())

  @@map("fg_incidents")
  @@index([zone, timestamp])
}

model SocialIncident {
  id        String   @id @default(uuid())
  text      String
  user      String
  zone      String
  riskFlag  Boolean  @default(false)
  timestamp DateTime @default(now())

  @@map("fg_social_incidents")
  @@index([zone, timestamp])
}

model Alert {
  id        String   @id @default(uuid())
  audience  Audience
  message   String
  riskTier  RiskTier
  createdAt DateTime @default(now())

  @@map("fg_alerts")
}

model OpsLog {
  id         String   @id @default(uuid())
  cycleId    String
  step       String
  status     String
  durationMs Int
  timestamp  DateTime @default(now())

  @@map("fg_ops_logs")
  @@index([cycleId, timestamp])
}
